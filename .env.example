# PostgreSQL (Render Managed Postgres yoki mahalliy)
DATABASE_URL="postgresql://user:password@host:5432/olmazor_nexus30?schema=public"

# NextAuth — productionda albatta to'liq domen URL
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# Production (Render): NEXTAUTH_URL="https://olmazor.nexus30.uz"

# Birinchi admin (npm run db:seed — faqat bir marta)
SEED_ADMIN_EMAIL="admin@nexus30.uz"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="NEXUS30 Admin"

# Ariza qabul yopilish vaqti (Toshkent, ISO 8601). Hakaton cheklovsiz (token orqali).
REGISTRATION_IDEATON_CLOSES_AT="2026-07-14T00:00:00+05:00"
REGISTRATION_STARTUP_CLOSES_AT="2026-07-16T00:00:00+05:00"
